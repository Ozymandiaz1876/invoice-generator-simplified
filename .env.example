# =============================================================================
# INVOICE GENERATOR - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Set to "true" to enable simplified invoice mode
# When enabled: uses simplified form, InvoiceTemplateSimple, INR currency
NEXT_PUBLIC_IS_SIMPLIFIED=false

# -----------------------------------------------------------------------------
# GOOGLE SEARCH CONSOLE
# -----------------------------------------------------------------------------
# Optional: Google Search Console verification code
GOOGLE_SC_VERIFICATION=

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (for sending invoices via email)
# -----------------------------------------------------------------------------
# Optional: Only needed if using email sending feature
NODEMAILER_EMAIL=your-email@gmail.com
NODEMAILER_PW=your-app-password

# -----------------------------------------------------------------------------
# BUNDLE ANALYZER (development only)
# -----------------------------------------------------------------------------
# Set to "true" to analyze bundle size on next build
ANALYZE=false
